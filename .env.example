GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# ============================================================
# Google Credentials Configuration
# ============================================================
#
# The application will automatically attempt to use:
# 1. Application Default Credentials (ADC)
#    - Recommended for GCP environments (Cloud Run, App Engine, GCE, etc.)
#    - No configuration needed if running in GCP with proper service account
#
# 2. Service Account JSON (for local development)
#    - Add your service account JSON key below
#
# Option 1: Direct JSON (one-line)
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
#
# Option 2: Base64 encoded JSON (useful for Docker/Cloud environments)
# GOOGLE_SERVICE_ACCOUNT_KEY_B64=base64_encoded_json_here
#
# To get service account credentials:
# 1. Go to Google Cloud Console: https://console.cloud.google.com/
# 2. Create a new project or select existing
# 3. Enable APIs: Google Sheets API, Google Drive API
# 4. Create a Service Account: IAM & Admin > Service Accounts
# 5. Generate JSON key and download the file
# 6. Use the JSON content for GOOGLE_SERVICE_ACCOUNT_KEY
#    (or base64 encode it for GOOGLE_SERVICE_ACCOUNT_KEY_B64)

# GOOGLE_SERVICE_ACCOUNT_KEY=your_service_account_json
# GOOGLE_SERVICE_ACCOUNT_KEY_B64=your_base64_encoded_json

# Optional: Port (default: 8080)
# PORT=8080
